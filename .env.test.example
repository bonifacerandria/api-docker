NODE_ENV=test
PORT=3001
API_PREFIX=/api/v1
LOG_LEVEL=dev

# Base de données DÉDIÉE aux tests - jamais la même que .env (dev) ou la prod.
# Les tests d'intégration font des TRUNCATE entre chaque cas : si ça pointait
# vers la base de dev, ils effaceraient tes données de développement à chaque run.
DATABASE_URL=postgres://taskflow_user:change_me_in_production@localhost:5432/taskflow_test
